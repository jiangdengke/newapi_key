NEW_API_BASE_URL=http://127.0.0.1:3000
NEW_API_USERNAME=your-admin-username
NEW_API_PASSWORD=your-admin-password

# Channel defaults are controlled by the server and cannot be overridden in the page.
CHANNEL_GROUP=anthropic
CHANNEL_NAME_PREFIX=claude
CHANNEL_START_NUMBER=1
CHANNEL_CONTINUE_FROM_EXISTING=true
# Use auto for the current MMDD, or provide a fixed four-digit value such as 0711.
CHANNEL_DATE_MODE=auto

# Local SQLite path, relative to the project root unless absolute.
DATABASE_PATH=data/channel-records.sqlite

# Optional: local bind address and port. Keep 127.0.0.1 outside Docker.
HOST=127.0.0.1
PORT=4173

# Structured JSON log level: debug, info, warn, or error.
LOG_LEVEL=info
