# 仅在系统中没有管理员时用于创建初始管理员，密码至少需要 10 个字符。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# 使用以下命令生成：openssl rand -base64 32
# 请妥善保存并保持此值不变，更换后将无法解密已保存的 New API 密码。
CREDENTIAL_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32

# 本地通过 HTTP 访问时设为 false；浏览器通过 HTTPS 访问时设为 true。
SESSION_COOKIE_SECURE=false

# 本地 SQLite 路径；如果不是绝对路径，则相对于项目根目录。
DATABASE_PATH=data/channel-records.sqlite

# 中文单行业务日志级别：debug、info、warn 或 error。
LOG_LEVEL=info

# 以下配置仅用于把旧版单实例数据迁移为初始实例，新部署不需要填写。
# 如需迁移，请取消这些配置的注释，并确保三个 NEW_API 连接项同时填写。
# 迁移成功后，New API 实例统一在系统管理端维护，可删除这些配置。
# NEW_API_BASE_URL=http://127.0.0.1:3000
# NEW_API_USERNAME=your-admin-username
# NEW_API_PASSWORD=your-admin-password
# NEW_API_INSTANCE_NAME=初始 New API

# 以下渠道默认值只用于上述初始实例。
# CHANNEL_GROUP=anthropic
# CHANNEL_NAME_PREFIX=claude
# CHANNEL_START_NUMBER=1
# CHANNEL_CONTINUE_FROM_EXISTING=true
# 渠道优先级允许负整数；渠道权重必须是非负整数。
# CHANNEL_PRIORITY=0
# CHANNEL_WEIGHT=0
# 使用 auto 表示采用当前 MMDD，也可以填写固定的四位值，例如 0711。
# CHANNEL_DATE_MODE=auto
